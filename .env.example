# PlotDNA — Environment Variables
# Copy to .env and fill in values. NEVER commit .env!

# ── Required for AI Verdict (Phase 1) ────────────────────────────────────────
GEMINI_API_KEY=.google.com/app/apikey
# Limits: 15 req/min, 1,500 req/day (free tier)

# ── CORS — tighten in production ─────────────────────────────────────────────
ALLOWED_ORIGINS=*
# Example restricted: https://plotdna.in,https://app.plotdna.in

# ── Phase 2: Supabase ────────────────────────────────────────────────────────
