# PlotDNA — Environment Variables
# Copy to .env and fill in values. NEVER commit .env!

# ── Required for AI Verdict (Phase 1) ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Free key: https://aistudio.google.com/app/apikey
# Limits: 15 req/min, 1,500 req/day (free tier)

# ── CORS — tighten in production ─────────────────────────────────────────────
ALLOWED_ORIGINS=*
# Example restricted: https://plotdna.in,https://app.plotdna.in

# ── Phase 2: Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Phase 3: Google Earth Engine ─────────────────────────────────────────────
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./gee-key.json

# ── Optional ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
APP_ENV=development
