# PlotDNA Environment Variables
# Copy to .env for local backend development. Never commit real secrets.

# Frontend deployment (Vercel)
# Set this in Vercel Project Settings -> Environment Variables.
# Required for brochure upload, map-link resolution, AI verdicts, and live OSM scoring.
VITE_API_URL=https://plotdna-api.onrender.com

# Backend deployment (Render)
# Set this in Render Dashboard -> plotdna-api -> Environment.
# Required for brochure upload and AI verdict features.
GEMINI_API_KEY=your_gemini_api_key_here
# Create a key at: https://aistudio.google.com/app/apikey
# Do not commit a real API key to this file.

# CORS - tighten in production once custom domains are final.
ALLOWED_ORIGINS=*
# Example restricted value:
# ALLOWED_ORIGINS=https://plotdna.in,https://app.plotdna.in

# Phase 2: Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Phase 3: Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./gee-key.json

# Optional
REDIS_URL=redis://localhost:6379
APP_ENV=development

# Optional OSM / Overpass cache. Defaults to a temp folder if not set.
OSM_CACHE_DIR=
OSM_CACHE_TTL_SECONDS=86400
