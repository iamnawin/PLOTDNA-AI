# PlotDNA environment variables
# Copy to .env and fill in real values. Never commit .env.

# Runtime
APP_ENV=development
DEBUG=false
ALLOWED_ORIGINS=*

# Auth / access gating
# Production must use a long random secret. Example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-long-random-secret
FREE_SEARCH_LIMIT=5

# AI providers
GEMINI_API_KEY=
GEMINI_CHAT_MODELS=gemini-1.5-flash
GEMINI_BROCHURE_MODELS=gemini-2.0-flash,gemini-1.5-flash
AI_PROVIDER_ORDER=gemini,nvidia,fallback
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODELS=moonshotai/kimi-k2.6

# News and public data providers
NEWS_API_KEY=
DLD_API_KEY=
API_SETU_KEY=

# Optional persistence
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=

# Optional Google Earth Engine
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=

# Optional cache / queues
REDIS_URL=redis://localhost:6379

# Brochure uploads
MAX_BROCHURE_SIZE_MB=10
UPLOAD_TEMP_DIR=
